# ============================================
# Configurações do Calosum Agent (Local/Ollama Profile)
# ============================================

# Motor Lógico do Hemisfério Esquerdo (Ollama Local)
# A engine rodará localmente no seu Mac na porta 11434. O Docker acessa o hospedeiro via "host.docker.internal".
CALOSUM_LEFT_ENDPOINT="http://localhost:11434/v1/chat/completions"
CALOSUM_LEFT_API_KEY="ollama"
CALOSUM_LEFT_MODEL="qwen3.5:latest"

# Porta Exposta da API do Orchestrator
CALOSUM_API_PORT=8000
